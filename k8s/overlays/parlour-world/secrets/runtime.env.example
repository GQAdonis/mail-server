# Copy to runtime.env (gitignored) and set real values.
# STALWART_PG_PASSWORD must match POSTGRES_PASSWORD in postgres.env.
STALWART_PG_PASSWORD=REPLACE_ME_postgres_password
# GCS HMAC interop SECRET key (the access key *id* is a literal in
# config-bootstrap.json -> blobStore.accessKey, since Stalwart's S3 accessKey
# field accepts only a string, not an env-var reference).
STALWART_GCS_SECRET_KEY=REPLACE_ME_gcs_hmac_secret_key
